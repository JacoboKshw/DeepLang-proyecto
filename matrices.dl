print("  mat_ceros(filas,cols)       mat_identidad(n)")
print("  mat_suma(A,B,f,c)           mat_resta(A,B,f,c)")
print("  mat_escalar(A,f,c,k)        mat_mul(A,B,m,n,p)")
print("  mat_transpuesta(A,f,c)      mat_traza(A,n)")
print("  mat_inversa(A,n)            mat_det(A,n)")
print("  mat_imprimir(A,f,c)         vec_dot(u,v,n)")
